{
  "name": "banegasn",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "dev": "concurrently -k -n web,comments -c cyan,magenta \"ng serve\" \"pnpm dev:comments\"",
    "dev:comments": "tsx watch server/comments-dev.ts",
    "prebuild": "node generate-sitemap.js",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "start": "node dist/banegasn/server/server.mjs",
    "lint": "ng lint"
  },
  "private": true,
  "engines": {
    "node": "24"
  },
  "dependencies": {
    "@angular/animations": "^22.0.6",
    "@angular/cdk": "^22.0.4",
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/platform-browser-dynamic": "^22.0.6",
    "@angular/platform-server": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@angular/ssr": "^22.0.6",
    "express": "^4.18.2",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.10",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@types/express": "^4.17.17",
    "@types/node": "^26.1.1",
    "angular-eslint": "22.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "eslint": "^9.28.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.20.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.57.2"
