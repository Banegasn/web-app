/*
  Cloudflare cache rules for banegasn.dev

  - Hashed assets (JS, CSS, images with content hashes): cache 1 year (immutable)
  - HTML/SSR pages: short edge cache with SWR, must revalidate in browser
  - robots.txt, sitemap.xml, manifest: short cache
  - posts/*.md (API-like): no cache
*/

# Hashed assets — immutable, 1 year
/*.js
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable
/images/*
  Cache-Control: public, max-age=31536000, immutable

# HTML pages — short edge cache, browser must revalidate
/*
  Cache-Control: public, max-age=0, must-revalidate, s-maxage=600, stale-while-revalidate=86400

# SEO files — short cache
/robots.txt
  Cache-Control: public, max-age=3600, s-maxage=3600
/sitemap.xml
  Cache-Control: public, max-age=3600, s-maxage=3600
/site.webmanifest
  Cache-Control: public, max-age=3600

# Markdown posts (fetched by the app) — no cache
/posts/*.md
  Cache-Control: no-cache, no-store, must-revalidate
/posts/posts.json
  Cache-Control: no-cache, no-store, must-revalidate
